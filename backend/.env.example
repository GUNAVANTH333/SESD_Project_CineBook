# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase, Neon, Railway, or local)
DATABASE_URL=postgresql://user:password@host:5432/cinebook

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_this_to_a_long_random_string_access
JWT_REFRESH_SECRET=change_this_to_a_long_random_string_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Booking ─────────────────────────────────────────────────────────────────
# Minutes a seat stays locked while user completes payment
SEAT_LOCK_TTL_MINUTES=10

# ─── Admin ───────────────────────────────────────────────────────────────────
# Users who register with this key get the ADMIN role
ADMIN_REGISTRATION_KEY=cinebook-admin-2024

# ─── CORS ────────────────────────────────────────────────────────────────────
# Your deployed frontend URL (e.g. https://cinebook-frontend.onrender.com)
FRONTEND_URL=http://localhost:5173
